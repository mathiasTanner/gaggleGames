{
  "kind": "singleType",
  "collectionName": "games_pages",
  "info": {
    "singularName": "games-page",
    "pluralName": "games-pages",
    "displayName": "Games Page",
    "description": "Manage the editorial games page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "eyebrow": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "text"
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "introTitle": {
      "type": "string"
    },
    "introText": {
      "type": "richtext"
    },
    "featuredProductsTitle": {
      "type": "string"
    },
    "featuredProductsText": {
      "type": "text"
    },
    "blocks": {
      "type": "dynamiczone",
      "components": ["shared.media", "shared.quote", "shared.rich-text", "shared.slider"]
    }
  }
}
